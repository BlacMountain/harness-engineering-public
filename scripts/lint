#!/usr/bin/env sh
set -eu

scripts/harness-check
OLD_PREFIX='/Users/wuyou/Documents'
OLD_PATH="${OLD_PREFIX}/harness-engineering"
rg -n "$OLD_PATH" README.md AGENTS.md HARNESS_QUICKSTART.md ARCHITECTURE.md docs .harness templates && {
  printf '%s\n' 'legacy harness path found'
  exit 1
} || true
printf '%s\n' 'lint passed'
