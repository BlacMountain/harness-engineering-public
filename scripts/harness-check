#!/usr/bin/env python3
"""Validate the local harness policy layer without external dependencies."""

from __future__ import annotations

import os
import stat
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
MAX_AGENT_LINES_DEFAULT = 100


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def collect_list(policy_text: str, key: str) -> list[str]:
    lines = policy_text.splitlines()
    values: list[str] = []
    in_list = False
    indent = 0
    prefix = f"{key}:"

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if not line.startswith(" ") and stripped.endswith(":") and not stripped.startswith("-"):
            if in_list:
                break
        if stripped == prefix:
            in_list = True
            indent = len(line) - len(line.lstrip(" "))
            continue
        if in_list:
            current_indent = len(line) - len(line.lstrip(" "))
            if current_indent <= indent and not stripped.startswith("-"):
                break
            if stripped.startswith("- "):
                values.append(stripped[2:].strip().strip('"').strip("'"))
    return values


def collect_scalar(policy_text: str, key: str, default: str = "") -> str:
    prefix = f"{key}:"
    for line in policy_text.splitlines():
        stripped = line.strip()
        if stripped.startswith(prefix):
            return stripped[len(prefix):].strip().strip('"').strip("'")
    return default


def fail(errors: list[str], message: str) -> None:
    errors.append(message)


def check_required_paths(errors: list[str], policy_text: str) -> None:
    for rel in collect_list(policy_text, "required_files"):
        if not (ROOT / rel).is_file():
            fail(errors, f"missing required file: {rel}")
    for rel in collect_list(policy_text, "required_directories"):
        if not (ROOT / rel).is_dir():
            fail(errors, f"missing required directory: {rel}")


def check_commands(errors: list[str], policy_text: str) -> None:
    for rel in collect_list(policy_text, "required_commands"):
        path = ROOT / rel
        if not path.is_file():
            fail(errors, f"missing required command: {rel}")
            continue
        mode = path.stat().st_mode
        if not mode & stat.S_IXUSR:
            fail(errors, f"required command is not executable: {rel}")


def check_gitignore(errors: list[str], git_policy_text: str) -> None:
    gitignore = ROOT / ".gitignore"
    if not gitignore.is_file():
        fail(errors, "missing .gitignore")
        return
    content = read_text(gitignore)
    for entry in collect_list(git_policy_text, "required_gitignore_entries"):
        if entry not in content:
            fail(errors, f".gitignore missing required entry: {entry}")


def check_forbidden_present(errors: list[str], git_policy_text: str) -> None:
    for rel in collect_list(git_policy_text, "forbidden_paths"):
        pattern = rel.rstrip("/")
        if not pattern or "*" in pattern:
            continue
        path = ROOT / pattern
        if path.exists() and pattern == ".DS_Store":
            fail(errors, "local .DS_Store exists; remove it before committing")


def check_large_files(errors: list[str], git_policy_text: str) -> None:
    limit_mb = int(collect_scalar(git_policy_text, "large_artifact_limit_mb", "100"))
    limit_bytes = limit_mb * 1024 * 1024
    skip_dirs = {".git", ".venv", "node_modules", "dist", "build", "data", "datasets", "models", "outputs", "results"}

    for current_root, dirs, files in os.walk(ROOT):
        dirs[:] = [d for d in dirs if d not in skip_dirs]
        for name in files:
            path = Path(current_root) / name
            try:
                if path.stat().st_size > limit_bytes:
                    fail(errors, f"file exceeds {limit_mb} MB limit: {path.relative_to(ROOT)}")
            except OSError:
                continue


def check_legacy_entry(errors: list[str]) -> None:
    if (ROOT / "Agent.md").exists():
        fail(errors, "legacy Agent.md exists; use AGENTS.md only")


def check_agent_length(errors: list[str], architecture_policy_text: str) -> None:
    max_lines = int(collect_scalar(architecture_policy_text, "max_agent_entry_lines", str(MAX_AGENT_LINES_DEFAULT)))
    path = ROOT / "AGENTS.md"
    if path.is_file():
        count = len(read_text(path).splitlines())
        if count > max_lines:
            fail(errors, f"AGENTS.md has {count} lines; limit is {max_lines}")


def check_templates(errors: list[str]) -> None:
    project_types = [
        "source-repo",
        "infra-repo",
        "research-repo",
        "deployment-repo",
        "knowledge-repo",
    ]
    required = [
        "AGENTS.md",
        "README.md",
        "ARCHITECTURE.md",
        ".gitignore",
        ".harness/project-policy.yaml",
        ".harness/workspace-policy.yaml",
        ".harness/git-policy.yaml",
        ".harness/quality-policy.yaml",
        ".harness/architecture-policy.yaml",
        "docs/GIT_POLICY.md",
        "scripts/harness-check",
    ]
    for project_type in project_types:
        base = ROOT / "templates" / project_type
        if not base.is_dir():
            fail(errors, f"missing template directory: templates/{project_type}")
            continue
        for rel in required:
            if not (base / rel).is_file():
                fail(errors, f"template {project_type} missing {rel}")


def main() -> int:
    errors: list[str] = []
    project_policy = ROOT / ".harness/project-policy.yaml"
    git_policy = ROOT / ".harness/git-policy.yaml"
    architecture_policy = ROOT / ".harness/architecture-policy.yaml"

    for path in [project_policy, git_policy, architecture_policy]:
        if not path.is_file():
            fail(errors, f"missing policy file: {path.relative_to(ROOT)}")

    if project_policy.is_file():
        project_text = read_text(project_policy)
        check_required_paths(errors, project_text)
        check_commands(errors, project_text)
    if git_policy.is_file():
        git_text = read_text(git_policy)
        check_gitignore(errors, git_text)
        check_forbidden_present(errors, git_text)
        check_large_files(errors, git_text)
    if architecture_policy.is_file():
        check_agent_length(errors, read_text(architecture_policy))

    check_legacy_entry(errors)
    check_templates(errors)

    if errors:
        print("harness-check failed:")
        for error in errors:
            print(f"- {error}")
        return 1

    print("harness-check passed")
    return 0


if __name__ == "__main__":
    sys.exit(main())
