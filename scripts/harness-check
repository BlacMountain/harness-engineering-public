#!/usr/bin/env python3
"""Validate the local harness policy layer without external dependencies."""

from __future__ import annotations

import os
import stat
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
POLICY_FILE = ROOT / ".harness/policy.yaml"
LEGACY_POLICY_FILE_NAMES = [
    "project-policy.yaml",
    "workspace-policy.yaml",
    "git-policy.yaml",
    "quality-policy.yaml",
    "architecture-policy.yaml",
]
LEGACY_POLICY_FILES = [ROOT / ".harness" / name for name in LEGACY_POLICY_FILE_NAMES]
MAX_AGENT_LINES_DEFAULT = 100
ALLOWED_WORKSPACE_TYPES = {"single-repo", "mono-repo", "mono-workspace"}
REQUIRED_COMMANDS = {"setup", "lint", "test", "dev", "harness_check"}
REQUIRED_REPORT_FIELDS = {
    "files_changed",
    "policies_used",
    "commands_run",
    "git_status",
    "remaining_risks",
}
REQUIRED_MINIMUM_CHECKS = {
    "required files exist",
    "required directories exist",
    "command entry points exist and are executable",
    ".gitignore covers git forbidden paths",
    "large files are not tracked or staged",
    "single AGENTS.md entry is enforced",
    "AGENTS.md stays within the configured line limit",
    ".harness policy is consumed by scripts/harness-check",
}


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def clean_value(value: str) -> str:
    return value.strip().strip('"').strip("'")


def collect_list(policy_text: str, key: str) -> list[str]:
    lines = policy_text.splitlines()
    values: list[str] = []
    in_list = False
    indent = 0
    prefix = f"{key}:"

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if not line.startswith(" ") and stripped.endswith(":") and not stripped.startswith("-"):
            if in_list:
                break
        if stripped == prefix:
            in_list = True
            indent = len(line) - len(line.lstrip(" "))
            continue
        if in_list:
            current_indent = len(line) - len(line.lstrip(" "))
            if current_indent <= indent and not stripped.startswith("-"):
                break
            if stripped.startswith("- "):
                values.append(clean_value(stripped[2:]))
    return values


def collect_scalar(policy_text: str, key: str, default: str = "") -> str:
    prefix = f"{key}:"
    for line in policy_text.splitlines():
        stripped = line.strip()
        if stripped.startswith(prefix):
            return clean_value(stripped[len(prefix):])
    return default


def collect_mapping(policy_text: str, key: str) -> dict[str, str]:
    lines = policy_text.splitlines()
    values: dict[str, str] = {}
    in_mapping = False
    indent = 0
    prefix = f"{key}:"

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped == prefix:
            in_mapping = True
            indent = len(line) - len(line.lstrip(" "))
            continue
        if in_mapping:
            current_indent = len(line) - len(line.lstrip(" "))
            if current_indent <= indent:
                break
            if stripped.startswith("- ") or ":" not in stripped:
                continue
            name, value = stripped.split(":", 1)
            values[clean_value(name)] = clean_value(value)
    return values


def collect_list_mappings(policy_text: str, key: str) -> list[dict[str, str]]:
    lines = policy_text.splitlines()
    values: list[dict[str, str]] = []
    current: dict[str, str] | None = None
    in_list = False
    indent = 0
    prefix = f"{key}:"

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped == prefix:
            in_list = True
            indent = len(line) - len(line.lstrip(" "))
            continue
        if in_list:
            current_indent = len(line) - len(line.lstrip(" "))
            if current_indent <= indent and not stripped.startswith("-"):
                break
            if stripped.startswith("- "):
                if current:
                    values.append(current)
                current = {}
                item = stripped[2:].strip()
                if ":" in item:
                    name, value = item.split(":", 1)
                    current[clean_value(name)] = clean_value(value)
                continue
            if current is not None and ":" in stripped:
                name, value = stripped.split(":", 1)
                current[clean_value(name)] = clean_value(value)

    if current:
        values.append(current)
    return values


def parse_bool(value: str) -> bool | None:
    if value == "true":
        return True
    if value == "false":
        return False
    return None


def fail(errors: list[str], message: str) -> None:
    errors.append(message)


def check_required_paths(errors: list[str], policy_text: str) -> None:
    for rel in collect_list(policy_text, "required_files"):
        if not (ROOT / rel).is_file():
            fail(errors, f"missing required file: {rel}")
    for rel in collect_list(policy_text, "required_directories"):
        if not (ROOT / rel).is_dir():
            fail(errors, f"missing required directory: {rel}")


def check_commands(errors: list[str], policy_text: str) -> None:
    entrypoints = collect_mapping(policy_text, "commands")
    if not entrypoints:
        fail(errors, "policy must declare commands")

    missing_commands = sorted(REQUIRED_COMMANDS - set(entrypoints))
    for name in missing_commands:
        fail(errors, f"policy missing command entrypoint: {name}")

    for name, rel in entrypoints.items():
        check_executable(errors, rel, f"command entrypoint '{name}'")


def check_executable(errors: list[str], rel: str, label: str) -> None:
    path = ROOT / rel
    if not path.is_file():
        fail(errors, f"missing {label}: {rel}")
        return
    mode = path.stat().st_mode
    if not mode & stat.S_IXUSR:
        fail(errors, f"{label} is not executable: {rel}")


def check_gitignore(errors: list[str], git_policy_text: str) -> None:
    gitignore = ROOT / ".gitignore"
    if not gitignore.is_file():
        fail(errors, "missing .gitignore")
        return
    content = read_text(gitignore)
    for entry in collect_list(git_policy_text, "required_gitignore_entries"):
        if entry not in content:
            fail(errors, f".gitignore missing required entry: {entry}")


def check_forbidden_present(errors: list[str], git_policy_text: str) -> None:
    for rel in collect_list(git_policy_text, "forbidden_paths"):
        pattern = rel.rstrip("/")
        if not pattern or "*" in pattern:
            continue
        path = ROOT / pattern
        if path.exists() and pattern == ".DS_Store":
            fail(errors, "local .DS_Store exists; remove it before committing")


def check_large_files(errors: list[str], git_policy_text: str) -> None:
    limit_mb = int(collect_scalar(git_policy_text, "large_artifact_limit_mb", "100"))
    limit_bytes = limit_mb * 1024 * 1024
    skip_dirs = {".git", ".venv", "node_modules", "dist", "build", "data", "datasets", "models", "outputs", "results"}

    for current_root, dirs, files in os.walk(ROOT):
        dirs[:] = [d for d in dirs if d not in skip_dirs]
        for name in files:
            path = Path(current_root) / name
            try:
                if path.stat().st_size > limit_bytes:
                    fail(errors, f"file exceeds {limit_mb} MB limit: {path.relative_to(ROOT)}")
            except OSError:
                continue


def check_legacy_entry(errors: list[str]) -> None:
    if (ROOT / "Agent.md").exists():
        fail(errors, "legacy Agent.md exists; use AGENTS.md only")


def check_agent_length(errors: list[str], architecture_policy_text: str) -> None:
    max_lines = int(collect_scalar(architecture_policy_text, "max_agent_entry_lines", str(MAX_AGENT_LINES_DEFAULT)))
    path = ROOT / "AGENTS.md"
    if path.is_file():
        count = len(read_text(path).splitlines())
        if count > max_lines:
            fail(errors, f"AGENTS.md has {count} lines; limit is {max_lines}")


def check_policy_layer_declared(errors: list[str], policy_text: str) -> None:
    if ".harness/policy.yaml" not in collect_list(policy_text, "source_of_truth"):
        fail(errors, ".harness/policy.yaml must be listed in source_of_truth")
    if "machine-policy" not in policy_text:
        fail(errors, "policy must declare the machine-policy layer")


def check_quality_policy(errors: list[str], quality_policy_text: str) -> None:
    report_fields = set(collect_list(quality_policy_text, "verification_report_requires"))
    missing_report_fields = sorted(REQUIRED_REPORT_FIELDS - report_fields)
    for field in missing_report_fields:
        fail(errors, f"quality policy missing verification report field: {field}")

    minimum_checks = set(collect_list(quality_policy_text, "minimum_checks"))
    missing_minimum_checks = sorted(REQUIRED_MINIMUM_CHECKS - minimum_checks)
    for check in missing_minimum_checks:
        fail(errors, f"quality policy missing minimum check: {check}")


def check_workspace_policy(errors: list[str], workspace_policy_text: str) -> None:
    workspace_type = collect_scalar(workspace_policy_text, "workspace_type")
    if workspace_type not in ALLOWED_WORKSPACE_TYPES:
        fail(errors, f"invalid workspace_type: {workspace_type}")

    repository_root = collect_scalar(workspace_policy_text, "repository_root")
    if not repository_root or repository_root == "null":
        fail(errors, "workspace policy must declare repository_root")
    elif not (ROOT / repository_root).is_dir():
        fail(errors, f"repository_root does not exist or is not a directory: {repository_root}")

    repositories = collect_list_mappings(workspace_policy_text, "repositories")
    if not repositories:
        fail(errors, "workspace policy must list at least one repository")
    for repository in repositories:
        path = repository.get("path", "")
        role = repository.get("role", "")
        if not path:
            fail(errors, "workspace policy repository entry missing path")
            continue
        if not role:
            fail(errors, f"workspace policy repository entry missing role: {path}")
        if not (ROOT / path).exists():
            fail(errors, f"workspace policy repository path does not exist: {path}")

    git_init_policy = collect_mapping(workspace_policy_text, "git_init_policy")
    for key in [
        "allow_git_init_at_workspace_root",
        "require_confirmation_if_no_git_root",
        "require_status_before_changes",
    ]:
        value = git_init_policy.get(key)
        if parse_bool(value or "") is None:
            fail(errors, f"workspace git_init_policy must declare boolean {key}")

    boundary_rules = collect_list(workspace_policy_text, "boundary_rules")
    if not boundary_rules:
        fail(errors, "workspace policy must declare boundary_rules")


def main() -> int:
    errors: list[str] = []
    policy_text = ""

    if not POLICY_FILE.is_file():
        fail(errors, f"missing policy file: {POLICY_FILE.relative_to(ROOT)}")
    else:
        policy_text = read_text(POLICY_FILE)
        check_required_paths(errors, policy_text)
        check_commands(errors, policy_text)
        check_gitignore(errors, policy_text)
        check_forbidden_present(errors, policy_text)
        check_large_files(errors, policy_text)
        check_workspace_policy(errors, policy_text)
        check_quality_policy(errors, policy_text)
        check_agent_length(errors, policy_text)
        check_policy_layer_declared(errors, policy_text)

    for path in LEGACY_POLICY_FILES:
        if path.exists():
            fail(errors, f"legacy policy file exists: {path.relative_to(ROOT)}")

    check_legacy_entry(errors)

    if errors:
        print("harness-check failed:")
        for error in errors:
            print(f"- {error}")
        return 1

    print("harness-check passed")
    return 0


if __name__ == "__main__":
    sys.exit(main())
